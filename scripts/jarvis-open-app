    'inkscape':            ('Inkscape',        ['inkscape.desktop'], ['/usr/bin/inkscape']),
}

def try_launch(name, desktop_ids, cmds):
    for cmd in cmds:
        if os.path.exists(cmd) and os.access(cmd, os.X_OK):
            popen([cmd])
            speakprint(f'Abriendo {name}.')
            return True
    for did in desktop_ids:
        r = subprocess.run(
            ['/usr/bin/gtk-launch', did],
            stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL,
        )
        if r.returncode == 0:
            speakprint(f'Abriendo {name}.')
            return True
    return False

for key, (name, ids, cmds) in sorted(aliases.items(), key=lambda x: -len(x[0])):
    if site_match(target, key):
        if try_launch(name, ids, cmds):
            sys.exit(0)

# ── Búsqueda genérica en .desktop instalados ─────────────────────────────────
apps = []
for base in [Path('/usr/share/applications'), Path.home() / '.local/share/applications']:
    if not base.exists():
        continue
    for p in base.glob('*.desktop'):
        try:
            lines = p.read_text(errors='ignore').splitlines()
        except Exception:
            continue
        name = ''; hidden = nodisplay = False
        for line in lines:
            if line.startswith('Name=') and not name:
                name = line[5:]
            elif line.startswith('Hidden=true'):
                hidden = True
            elif line.startswith('NoDisplay=true'):
                nodisplay = True
        if name and not hidden and not nodisplay:
            apps.append((p.name, name, norm(name)))

tokens = set(target.split())
best   = None
for did, name, n in apps:
    score = 0
    if target == n:
        score += 100
    if target in n or n in target:
        score += 60
    score += 10 * len(tokens & set(n.split()))
    if score and (best is None or score > best[0]):
        best = (score, did, name)

if best and best[0] >= 20:
    if try_launch(best[2], [best[1]], []):
        sys.exit(0)

speakprint(f'No encontré una aplicación llamada {target}.')
sys.exit(1)
