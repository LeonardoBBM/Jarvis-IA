#!/usr/bin/env python3
import os, re, subprocess, sys, unicodedata, urllib.parse
from pathlib import Path

HOME = Path.home()

def norm(s):
    s = s.lower().strip()
    s = ''.join(c for c in unicodedata.normalize('NFD', s)
                if unicodedata.category(c) != 'Mn')
    s = re.sub(r'[^a-z0-9 +#./:-]+', ' ', s)
    return re.sub(r'\s+', ' ', s).strip()

def speakprint(s):
    print(s)

def popen(cmd):
    subprocess.Popen(cmd, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)

text = ' '.join(sys.argv[1:]).strip()
q    = norm(text)
# Quita cortesía y ruido.
q = re.sub(r'\b(por favor|en pantalla|ahora|para mi)\b', '', q).strip()

m = re.search(
    r'\b(?:abre|abrir|abra|obra|ejecuta|inicia|lanza|busca|buscar|pon|reproduce|googlea|google)\b'
    r'\s+(?:el |la |los |las |un |una |programa |aplicacion |app |pagina |sitio |web )?(.*)$', q)
target = m.group(1).strip() if m else q
if not target:
    sys.exit(2)

FIREFOX  = '/usr/bin/firefox'
XDG_OPEN = '/usr/bin/xdg-open'

def open_url(name, url):
    if os.path.exists(FIREFOX):
        popen([FIREFOX, url])
    else:
        popen([XDG_OPEN, url])
    speakprint(f'Abriendo {name}.')
    return True

def search_url(engine, query):
    quoted = urllib.parse.quote_plus(query)
    if engine == 'youtube':
        return f'https://www.youtube.com/results?search_query={quoted}'
    if engine == 'google':
        return f'https://www.google.com/search?q={quoted}'
    if engine == 'spotify':
        return f'https://open.spotify.com/search/{urllib.parse.quote(query)}'
    if engine == 'maps':
        return f'https://www.google.com/maps/search/{urllib.parse.quote_plus(query)}'
    return f'https://www.google.com/search?q={quoted}'


# ── Patrones completos (sobre la frase antes de extraer el verbo) ─────────────
full_patterns = [
    (r'(?:abre |abrir |abra |obra )?youtube(?: y)? (?:busca|buscar|pon|reproduce)\s+(.+)',
     'youtube', 'YouTube'),
    (r'(?:busca|buscar) (?:en )?youtube\s+(.+)',  'youtube', 'YouTube'),
    (r'(?:busca|buscar) (?:en )?google\s+(.+)',   'google',  'Google'),
    (r'(?:googlea|google)\s+(.+)',                'google',  'Google'),
    (r'(?:busca|buscar) (?:en )?maps?\s+(.+)',    'maps',    'Google Maps'),
    (r'(?:pon|reproduce) musica(?: para)?\s*(.*)', 'youtube', 'música en YouTube'),
    (r'musica(?: para)?\s*(.*)',                   'youtube', 'música en YouTube'),
    (r'(?:pon|reproduce)\s+(.+)',                  'youtube', 'YouTube'),
]

BASE_URLS = {
    'youtube': 'https://www.youtube.com',
    'google':  'https://www.google.com',
    'spotify': 'https://open.spotify.com',
    'maps':    'https://www.google.com/maps',
}

def prehandle_full_phrase(q):
    for rx, engine, label in full_patterns:
        mm = re.fullmatch(rx, q)
        if mm:
            query = (mm.group(1) or '').strip()
            if query:
                open_url(label, search_url(engine, query))
            else:
                open_url(label, BASE_URLS.get(engine, 'https://www.google.com'))
            return True
    return False

if prehandle_full_phrase(q):
    sys.exit(0)

# ── Patrones de búsqueda/reproducción sobre `target` ─────────────────────────
patterns = [
    (r'(?:abre |abrir |abra |obra )?youtube (?:y )?(?:busca|buscar|pon|reproduce)?\s*(.*)',
     'youtube', 'YouTube'),
    (r'(?:busca|buscar) (?:en )?youtube\s+(.*)',  'youtube', 'YouTube'),
    (r'(?:busca|buscar) (?:en )?google\s+(.*)',   'google',  'Google'),
    (r'(?:busca|buscar) (?:en )?maps?\s+(.*)',     'maps',    'Google Maps'),
    (r'en google\s+(.*)',                          'google',  'Google'),
    (r'(?:googlea|google)\s+(.*)',                 'google',  'Google'),
    (r'(?:pon|reproduce) musica(?: para)?\s*(.*)', 'youtube', 'música en YouTube'),
    (r'musica(?: para)?\s*(.*)',                   'youtube', 'música en YouTube'),
    (r'(?:pon|reproduce)\s+(.*)',                  'youtube', 'YouTube'),
    (r'(?:abre |abrir |abra |obra )?spotify (?:y )?(?:busca|buscar|pon|reproduce)?\s*(.*)',
     'spotify', 'Spotify'),
]
for rx, engine, label in patterns:
    mm = re.fullmatch(rx, target)
    if mm:
        query = (mm.group(1) or '').strip()
        if query:
            open_url(label, search_url(engine, query))
        else:
            open_url(label, BASE_URLS.get(engine, 'https://www.google.com'))
        sys.exit(0)

# ── Sitios web ────────────────────────────────────────────────────────────────
