if target.startswith(('http://', 'https://')):
    open_url(target, target)
    sys.exit(0)

# Búsqueda con coincidencia exacta primero, luego por palabras completas.
def site_match(t, key):
    """True si t == key o key aparece como palabra completa dentro de t."""
    if t == key:
        return True
    # Palabra completa: key rodeado de inicio/fin de cadena o espacio.
    return bool(re.search(r'(^|\s)' + re.escape(key) + r'($|\s)', t))

for key, (name, url) in sorted(sites.items(), key=lambda x: -len(x[0])):
    if site_match(target, key):
        open_url(name, url)
        sys.exit(0)

if target in {'navegador', 'firefox', 'mozilla'}:
    open_url('Firefox', 'about:home')
    sys.exit(0)
if target == 'google':
    open_url('Google', 'https://www.google.com')
    sys.exit(0)


# ── Carpetas y archivos ───────────────────────────────────────────────────────
folder_aliases = {
    'escritorio':  HOME / 'Escritorio',
    'descargas':   HOME / 'Descargas',
    'documentos':  HOME / 'Documentos',
    'imagenes':    HOME / 'Imágenes',
    'imágenes':    HOME / 'Imágenes',
    'musica':      HOME / 'Música',
    'música':      HOME / 'Música',
    'videos':      HOME / 'Vídeos',
    'vídeos':      HOME / 'Vídeos',
    'gimnasio':    HOME / 'Escritorio' / 'Personal' / 'Gimnasio',
}
for key, folder in folder_aliases.items():
    patterns_folder = [key, f'carpeta {key}', f'mi {key}', f'la carpeta {key}']
    if any(p in target for p in patterns_folder):
        if folder.exists():
            popen([XDG_OPEN, str(folder)])
            speakprint(f'Abriendo {key}.')
            sys.exit(0)

# ── Búsqueda de archivos ──────────────────────────────────────────────────────
if any(word in target for word in ['tarea', 'archivo', 'documento', 'excel', 'word']):
    roots = [HOME / 'Escritorio', HOME / 'Documentos', HOME / 'Descargas']
    query = re.sub(
        r'\b(mi|la|el|archivo|documento|tarea|abre|abrir|word|excel)\b', ' ', target
    ).strip()
    candidates = []
    for root in roots:
        if not root.exists():
            continue
        for ext in ('*.docx', '*.xlsx', '*.pdf', '*.txt', '*.odt', '*.ods', '*.pptx'):
            for f in root.rglob(ext):
                try:
                    if any(part.startswith('.') for part in f.relative_to(root).parts):
                        continue
                except Exception:
                    pass
                nf    = norm(f.stem)
                score = 0
                if query and query in nf:
                    score += 80
                score += 12 * len(set(query.split()) & set(nf.split())) if query else 0
                if score or not query:
                    candidates.append((score, f.stat().st_mtime, f))
    if candidates:
        candidates.sort(key=lambda x: (x[0], x[1]), reverse=True)
        f = candidates[0][2]
        popen([XDG_OPEN, str(f)])
        speakprint(f'Abriendo {f.name}.')
        sys.exit(0)

